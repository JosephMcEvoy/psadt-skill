# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# PSADT Package Test VM
# Generated by vagrant-test skill
#
# Usage:
#   Use run_test.ps1 to drive the full lifecycle (handles file copy + provisioners)

# === CONFIGURE THESE ===
VM_NAME      = "__VM_NAME__"
VM_MEMORY    = 4096
VM_CPUS      = 2
SWITCH_NAME  = "__SWITCH_NAME__"
# =======================

Vagrant.configure("2") do |config|
  config.vm.box = "gusztavvargadr/windows-11"
  config.vm.hostname = VM_NAME
  config.vm.communicator = "winrm"
  config.winrm.username = "vagrant"
  config.winrm.password = "vagrant"
  config.winrm.timeout = 600
  config.winrm.retry_limit = 20

  # Disable default synced folder (run_test.ps1 uses Copy-VMFile instead)
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # Hyper-V provider settings
  config.vm.provider "hyperv" do |h|
    h.vmname = VM_NAME
    h.memory = VM_MEMORY
    h.cpus = VM_CPUS
    h.enable_virtualization_extensions = false
    h.linked_clone = true
    if SWITCH_NAME && !SWITCH_NAME.empty? && SWITCH_NAME != "__SWITCH_NAME__"
      h.switch_name = SWITCH_NAME
    end
  end

  # --- Provisioner: Install ---
  config.vm.provision "install", type: "shell", run: "never" do |s|
    s.powershell_elevated_interactive = false
    s.inline = <<-SCRIPT
      Set-Location "C:\\vagrant_package"
      $result = @{ StartTime = (Get-Date -Format o); ExitCode = $null; Error = $null }
      try {
        & powershell.exe -ExecutionPolicy Bypass -File "Invoke-AppDeployToolkit.ps1" -DeployMode Silent
        $result.ExitCode = $LASTEXITCODE
      } catch {
        $result.ExitCode = 1
        $result.Error = $_.Exception.Message
      }
      $result.EndTime = (Get-Date -Format o)
      $result | ConvertTo-Json | Set-Content "C:\\vagrant_results\\install_result.json" -Encoding UTF8
      Write-Host "Install exit code: $($result.ExitCode)"
    SCRIPT
  end

  # --- Provisioner: Validate ---
  config.vm.provision "validate", type: "shell", run: "never" do |s|
    s.powershell_elevated_interactive = false
    s.path = "scripts/validate.ps1"
  end

  # --- Provisioner: Uninstall ---
  config.vm.provision "uninstall", type: "shell", run: "never" do |s|
    s.powershell_elevated_interactive = false
    s.inline = <<-SCRIPT
      Set-Location "C:\\vagrant_package"
      $result = @{ StartTime = (Get-Date -Format o); ExitCode = $null; Error = $null }
      try {
        & powershell.exe -ExecutionPolicy Bypass -File "Invoke-AppDeployToolkit.ps1" -DeploymentType Uninstall -DeployMode Silent
        $result.ExitCode = $LASTEXITCODE
      } catch {
        $result.ExitCode = 1
        $result.Error = $_.Exception.Message
      }
      $result.EndTime = (Get-Date -Format o)
      $result | ConvertTo-Json | Set-Content "C:\\vagrant_results\\uninstall_result.json" -Encoding UTF8
      Write-Host "Uninstall exit code: $($result.ExitCode)"
    SCRIPT
  end
end
